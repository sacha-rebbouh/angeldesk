# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/.codex-temp/

# gate Codex + relais autonome de session (artefacts locaux, hors payload du gate)
/.codex-gate-thread
/.codex-gate-log.md
/.codex-gate-resume.md
/.codex-gate-relay-count
/.codex-relay-up
/.codex-relay-dead
/STOP

# env files (can opt-in for committing if needed)
.env*
# ...but the root example template IS committed (no secrets, onboarding doc).
!/.env.example

# vercel
.vercel

# local uploads (dev only)
/public/uploads

# local Prisma scratch databases
/prisma/dev.db

# typescript
*.tsbuildinfo
next-env.d.ts

*storybook.log
storybook-static

# Phase 5 E2E smoke fixtures — regenerated by scripts/e2e/generate-fixtures.ts
/scripts/e2e/fixtures/
.env*.local

# Phase B14/B15/B16/B17 audit evidence (screenshots, PDFs, reports, runner output)
# — re-generable on demand, do not pollute git history.
/scripts/debug/

# scratch / audit handoff (Codex audits, draft docs, ad-hoc dumps)
/temp/
