# ============================================================================
# Angel Desk — example environment.
# Copy to .env.local and fill in. Platform-injected vars (NODE_ENV, VERCEL_*,
# NEXT_RUNTIME, PATH) are NOT listed here — they are set by the runtime.
# Commented lines are optional; uncommented lines are required for a full run.
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (Required) — Neon Postgres. DIRECT_URL bypasses the pooler for
# migrations. ⚠️ Prod migrations are applied BY HAND (see README), never auto.
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# ----------------------------------------------------------------------------
# CLERK AUTH (Required)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard

# ----------------------------------------------------------------------------
# LLM GATEWAY (Required) — OpenRouter
# ----------------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-...
# THESIS_MODEL_TIER=          # override the model tier used by thesis-extractor
# LLM_LOG_RAW_TEXT=false      # log raw LLM prompts/responses (dev only; PII risk)

# ----------------------------------------------------------------------------
# STORAGE (Required for uploads) — Vercel Blob
# ----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=...

# ----------------------------------------------------------------------------
# SECURITY (Required) — AES key encrypting the document corpus at rest (PII).
# 32-byte key, base64 or hex. Rotating it makes existing encrypted rows unreadable.
# ----------------------------------------------------------------------------
DOCUMENT_ENCRYPTION_KEY=...

# ----------------------------------------------------------------------------
# APP CONFIG (Required)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
# APP_URL=http://localhost:3000   # server-side absolute URL (falls back to VERCEL_URL)

# ----------------------------------------------------------------------------
# CRON / BACKGROUND JOBS
# ----------------------------------------------------------------------------
CRON_SECRET=your-secure-cron-secret-min-32-chars
# INNGEST_SIGNING_KEY=signkey-...
# INNGEST_ENV=                 # Inngest environment branch override

# ----------------------------------------------------------------------------
# DISTRIBUTED STATE (Recommended in prod) — Upstash Redis. Without it, rate-limit
# and upload-progress fall back to in-memory (per-instance) and lose cross-instance
# coordination on serverless.
# ----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ----------------------------------------------------------------------------
# OBSERVABILITY (Recommended in prod)
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# LOG_LEVEL=info               # debug | info | warn | error (default: info in prod)
# ADMIN_DEBUG_COST_THRESHOLD_USD=   # alert threshold for per-analysis cost

# ----------------------------------------------------------------------------
# FEATURE FLAGS (Optional — server runtime, no NEXT_PUBLIC; toggle without redeploy)
# ----------------------------------------------------------------------------
# DEEP_DIVE_STEPWISE=true      # durable step-by-step Deep Dive (Inngest stepwise v3)
# LIVE_COACHING_ENABLED=false  # Live Coaching tab + Recall.ai pipeline
# SHOW_CONDITIONS_TAB=false    # archived Conditions tab
# EXTRACTION_RENDERER=         # document renderer override
# EXTRACTION_STRICT_READINESS=  # strict extraction-readiness gating
# BOARD_CONFIG=test            # 'test' = cheap models, 'prod' = premium models

# ----------------------------------------------------------------------------
# DOCUMENT EXTRACTION / OCR (Optional — fallbacks; built-in PDF parse works without)
# ----------------------------------------------------------------------------
# POPPLER_BIN=                 # path to poppler binaries (pdftoppm) if not on PATH
# Azure Document Intelligence
# AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://...
# AZURE_DOCUMENT_INTELLIGENCE_API_KEY=...
# AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=
# AZURE_DOCUMENT_INTELLIGENCE_MODEL_ID=
# Google Document AI (one auth method)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_DOCUMENT_AI_PROCESSOR_NAME=projects/.../processors/...
# GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT_JSON=
# GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT_BASE64=
# GOOGLE_DOCUMENT_AI_SERVICE_ACCOUNT_FILE=
# GOOGLE_DOCUMENT_AI_CLIENT_EMAIL=
# GOOGLE_DOCUMENT_AI_PRIVATE_KEY=
# GOOGLE_DOCUMENT_AI_ACCESS_TOKEN=
# GOOGLE_DOCUMENT_AI_TOKEN_URI=
# GOOGLE_DOCUMENT_AI_USE_METADATA_AUTH=

# ----------------------------------------------------------------------------
# LIVE COACHING (Optional — only if LIVE_COACHING_ENABLED=true)
# ----------------------------------------------------------------------------
# RECALL_AI_API_KEY=...
# RECALL_API_REGION=
# RECALL_WEBHOOK_SECRET=...
# RECALL_WEBHOOK_BYPASS_SIGNATURE=    # dev only — skip webhook signature check
# LIVE_TRANSCRIPT_WEBHOOK_SECRET=...
# LIVE_TRANSCRIPT_BYPASS_SIGNATURE=   # dev only
# ABLY_API_KEY=...             # realtime transport for live UI
# WS_RELAY_URL=                # websocket relay for transcripts
# WS_RELAY_SECRET=

# ----------------------------------------------------------------------------
# NOTIFICATIONS (Optional)
# ----------------------------------------------------------------------------
# RESEND_API_KEY=re_...        # transactional email (analysis-ready, etc.)
# ADMIN_EMAIL=admin@example.com
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_ADMIN_CHAT_ID=your-chat-id
# TELEGRAM_WEBHOOK_SECRET=your-webhook-secret   # required if TELEGRAM_BOT_TOKEN is set

# ----------------------------------------------------------------------------
# EXTERNAL DATA ENRICHMENT (Optional — Context Engine degrades gracefully without)
# ----------------------------------------------------------------------------
# SERPER_API_KEY=your-serper-key
# BRAVE_API_KEY=your-brave-key
# NEWS_API_KEY=your-newsapi-key
# GITHUB_TOKEN=ghp_...
# CRUNCHBASE_API_KEY=your-crunchbase-key
# COMPANIES_HOUSE_API_KEY=your-companies-house-key   # UK company data
# PAPPERS_API_KEY=your-pappers-key                   # French company data
# PROXYCURL_API_KEY=your-proxycurl-key               # LinkedIn (one of three)
# APIFY_API_KEY=your-apify-key                       # LinkedIn
# RAPIDAPI_LINKEDIN_KEY=your-rapidapi-key            # LinkedIn
# PRODUCT_HUNT_TOKEN=your-ph-token
# PRODUCTHUNT_API_KEY=your-ph-api-key
# INDEED_PROXY_URL=your-indeed-proxy

# ----------------------------------------------------------------------------
# DEVELOPMENT / TEST ONLY
# ----------------------------------------------------------------------------
# BYPASS_AUTH=true             # bypass Clerk in dev (NEVER in prod)
# SKIP_DB_TESTS=1              # skip DB-integration tests in the unit run
# ALLOW_REMOTE_DB=1            # allow DB tests against a remote (*.neon.tech) URL — danger
